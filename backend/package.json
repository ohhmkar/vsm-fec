{
  "name": "vsm-server",
  "version": "1.0.0",
  "description": "Server for Oculus VSM 2024",
  "main": "src/app.ts",
  "type": "commonjs",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --report-unused-disable-directives \"src/**/*.ts\"",
    "build": "tsc",
    "start": "tsx src/app.ts",
    "start:dev": "tsx watch --clear-screen=false src/app.ts",
    "start:prod": "node dist/app.js",
    "db:push": "prisma db push",
    "postinstall": "prisma generate",
    "seed": "tsx src/seed.ts",
    "test:buy": "tsx load-test/pure-buy.ts",
    "test:sell": "tsx load-test/pure-sell.ts",
    "test:demo": "tsx load-test/demo-50-users.ts",
    "db:reset": "tsx src/reset-and-seed.ts"
  },
  "keywords": [],
  "author": "lanceHoenhymmm",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.8.3",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "prisma": "^5.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
