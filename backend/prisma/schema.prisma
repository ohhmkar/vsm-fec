generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model User {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email    String  @unique
  password String
  u1Name   String  @map("u1Name")
  u2Name   String? @map("u2Name")
  isAdmin  Boolean @default(false) @map("is_admin")

  account      PlayerAccount?
  transactions Transaction[]

  @@map("users")
}

model PlayerAccount {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String @unique @map("user_id") @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  isBanned Boolean @default(false) @map("is_banned")

  recentlySoldStocks Json   @default("[]") @map("recently_sold_stocks")
  ipoClaimedSymbols  Json   @default("[]") @map("ipo_claimed_symbols")

  portfolio PlayerPortfolio?
  powerups  PlayerPowerups?

  @@map("player_account")
}

model PlayerPortfolio {
  playerId String        @id @map("player_id") @db.Uuid
  player   PlayerAccount @relation(fields: [playerId], references: [id], onDelete: Cascade)

  bankBalance         Float @map("bank_balance")
  totalPortfolioValue Float @map("total_portfolio_value")
  stocks              Json

  @@map("player_portfolio")
}

model Stock {
  symbol          String  @id @db.VarChar
  name            String? @map("name")
  sector          String? @map("sector")
  roundIntroduced Int     @map("round_introduced") @db.SmallInt
  price           Float
  volatility      Float

  dividendAmount    Float   @default(0) @map("dividend_amount")
  ipoPrice          Float?  @map("ipo_price")
  ipoRound          Int?    @map("ipo_round")
  availableInIPO    Boolean @default(false) @map("available_in_ipo")

  transactions Transaction[]

  @@map("stocks_game")
}

model StockGameData {
  id         Int    @id @default(autoincrement())
  symbol     String @db.VarChar
  forRound   Int    @map("round_applicable") @db.SmallInt
  volatility Float

  @@map("stocks")
}

model News {
  id              Int     @id @default(autoincrement())
  content         String
  forInsider      Boolean @default(false) @map("for_insider")
  roundApplicable Int     @map("round_applicable")

  type          NewsType @default(GENERATED)
  sentiment     String   @default("NEUTRAL")
  affectedStocks Json?   @map("affected_stocks")
  isAdminNews    Boolean @default(false) @map("is_admin_news")
  priceImpact    Float   @default(0) @map("price_impact")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("news")
}

enum NewsType {
  GENERATED
  ADMIN
}

model GameState {
  id            String   @id @default("state")
  currentRound  Int      @default(0) @map("current_round")
  isRoundActive Boolean  @default(false) @map("is_round_active")
  roundStartTime DateTime? @map("round_start_time")
  roundDuration  Int?      @map("round_duration") // in minutes, for current active round
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("game_state")
}

model RoundConfig {
  roundNo     Int      @id @map("round_no")
  duration    Int      @map("duration") // in minutes
  description String?
  rules       Json?    @default("{}")
  scheduledStartTime DateTime? @map("scheduled_start_time")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("round_config")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id") @db.Uuid
  user        User            @relation(fields: [userId], references: [id])
  stockSymbol String          @map("stock_symbol") @db.VarChar
  stock       Stock           @relation(fields: [stockSymbol], references: [symbol])
  type        TransactionType
  quantity    Int
  price       Float
  total       Float
  round       Int
  timestamp   DateTime        @default(now())

  @@map("transactions")
}

enum TransactionType {
  BUY
  SELL
}

model PlayerPowerups {
  playerId String @id @map("player_id") @db.Uuid
  player   PlayerAccount @relation(fields: [playerId], references: [id], onDelete: Cascade)

  insiderTradingStatus     String  @default("Unused") @map("insider_trading_status") @db.VarChar
  muftKaPaisaStatus        String  @default("Unused") @map("muft_ka_paisa_status") @db.VarChar
  stockBettingStatus       String  @default("Unused") @map("stock_betting_status") @db.VarChar
  stockBettingAmount       Float?  @map("stock_betting_amount")
  stockBettingPrediction   String? @map("stock_betting_prediction") @db.Char(2)
  stockBettingLockedSymbol String? @map("stock_betting_locked_symbol") @db.VarChar
  stockBettingLockedPrice  Float? @map("stock_betting_locked_price")

  @@map("player_powerups")
}

model IPOAllocation {
  id        String   @id @default(uuid())
  playerId  String   @map("player_id") @db.Uuid
  symbol    String   @map("symbol") @db.VarChar
  quantity  Int      @map("quantity")
  price     Float    @map("price")
  round     Int      @map("round")
  claimed   Boolean  @default(false) @map("claimed")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([playerId, symbol, round])
  @@map("ipo_allocations")
}

model DividendDeclaration {
  id        String   @id @default(uuid())
  symbol    String   @map("symbol") @db.VarChar
  amount    Float    @map("amount")
  round     Int      @map("round")
  processed Boolean  @default(false) @map("processed")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([symbol, round])
  @@map("dividend_declarations")
}
